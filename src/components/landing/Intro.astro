---
// Foundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const introSections = [
  {
    title: "Precision First",
    description:
      "Every detail starts with a careful inspection, not shortcuts. We use professional-grade products and proven techniques to deliver consistent, high-quality results.",
  },
  {
    title: "Work That Holds Up",
    description:
      "Every service is performed with long-lasting results in mind — premium products, meticulous workmanship, and zero tolerance for shortcuts.",
  },
  {
    title: "Straightforward Service",
    description:
      "We tell you what matters, what's recommended, and what's optional. Clear pricing, honest recommendations, and communication you never have to chase.",
  },
  {
    title: "A Team That Gives a Damn",
    description:
      "Spot On Mobile Detailing is built by people who take pride in doing the job right. Skill, consistency, and a genuine respect for every customer who trusts us with their vehicle.",
  },
];
---

<section class="bg-gradient-to-t from-base-200 to-white">
  <Wrapper variant="standard" class="py-24">
    <div>
      <Text
        tag="h2"
        variant="displayXL"
        class="uppercase font-display text-base-900"
      >
        The difference is in the details
      </Text>
      <Text tag="p" variant="textLG" class="mt-2 text-base-500 text-balance">
        From the products we use to the time we spend on every vehicle, quality isn't an upgrade - it's our standard.
      </Text>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        introSections.map((section) => (
          <div class="p-6 shadow-2xl pt-42 bg-base-50 rounded-3xl outline-4 outline-base-500/10">
            <Text
              tag="h3"
              variant="textBase"
              class="pl-4 font-medium uppercase border-l-2 font-display text-base-900 border-accent-500 "
            >
              {section.title}
            </Text>
            <Text
              tag="p"
              variant="textXS"
              class="mt-4 text-base-600 text-balance"
            >
              {section.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
