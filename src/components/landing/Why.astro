---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    title: "Expert Care",
    description:
      "Our experience, professional-grade products, and attention to detail ensure every vehicle receives the care it deserves.",
  },
  {
    title: "Transparent Pricing",
    description:
      "No hidden fees or surprises. We provide clear pricing and straightforward recommendations before any work begins.",
  },
  {
    title: "Premium Products",
    description:
      "We use trusted detailing products and ceramic coating solutions designed to enhance appearance, protection, and long-term results.",
  },
  {
    title: "Satisfaction Guaranteed",
    description:
      "We stand behind our work and take pride in delivering results that leave our customers confident and satisfied.",
  },
];
---

<section class="bg-linear-to-t from-base-200 to-white">
  <Wrapper variant="standard" class="py-24">
    <div class="items-start grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div>
        <Text
          tag="span"
          variant="textSM"
          class="pl-4 font-medium uppercase border-l text-base-900 font-display border-accent-500"
        >
          Why Choose Us
        </Text>
        <Text
          tag="h2"
          variant="displayMD"
          class="mt-8 uppercase font-display text-base-900"
        >
          The Spot On <br /> Difference
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="mt-4 text-base-600 text-balance"
        >
          We're not just another detailing company. We're passionate about helping vehicle owners protect their investment and take pride in every service we perform.
        </Text>
      </div>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4 lg:col-span-2">
        {
          features.map((feature) => (
            <div class="flex flex-col p-6 shadow-2xl pt-42 bg-base-50 rounded-3xl outline-4 outline-base-500/10">
              <Text
                tag="h3"
                variant="textBase"
                class="pl-4 font-medium uppercase border-l-2 font-display text-base-900 border-accent-500 "
              >
                {feature.title}
              </Text>
              <Text
                tag="p"
                variant="textXS"
                class="mt-4 text-base-600 text-balance"
              >
                {feature.description}
              </Text>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
