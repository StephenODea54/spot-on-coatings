---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";
const footerLinks = [
  {
    title: "Services",
    links: [
      { label: "Service Packages", href: "/services" },
      { label: "Book Appointment", href: "/contact" },
    ],
  },
];
---

<footer class="relative w-full overflow-hidden lg:p-8">
  <div class="absolute inset-0 overflow-hidden lg:m-4 lg:rounded-3xl">
    <video
      class="object-cover object-center size-full"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/videos/car3.mp4" type="video/mp4" />
    </video>
    <div
      aria-hidden="true"
      class="absolute inset-0 pointer-events-none bg-base-950/90"
    >
    </div>
  </div>
  <Wrapper
    variant="standard"
    class="relative z-10 flex flex-col justify-between h-full pt-24 pb-8 gap-8 lg:gap-44"
  >
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-12">
      <div class="col-span-2">
        <a href="/" aria-label="Go to home page">
          <Logo class="text-lg font-medium text-white uppercase font-display" />
        </a>
        <Text tag="p" variant="textXS" class="max-w-sm mt-2 text-base-500">
          Spot On Mobile Detailing provides professional mobile detailing and
          ceramic coating services designed to keep your vehicle looking its
          absolute best. Quality results, honest service, and attention to
          detail are at the heart of everything we do.
        </Text>
      </div>
      {
        footerLinks.map((section) => (
          <div>
            <Text
              tag="h3"
              variant="textSM"
              class="font-medium text-white uppercase font-display"
            >
              {section.title}
            </Text>
            <ul class="mt-2 space-y-1">
              {section.links.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="flex text-xs text-base-500 hover:text-white transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <div
        class="grid grid-cols-2 lg:grid-cols-1 gap-8 col-span-2 lg:col-span-1"
      >
        <div>
          <Text
            tag="h4"
            variant="textSM"
            class="font-medium text-white uppercase font-display"
          >
            Office
          </Text>
          <address
            class="mt-2 text-xs not-italic leading-relaxed text-base-500"
          >
            248 Morrison St<br />
            Struthers, OH 44471
          </address>
        </div>
        <div>
      </div>
    </div>
    </div>
    <div>
      <div
        class="flex flex-col justify-between mt-auto md:flex-row lg:items-center gap-4"
      >
        <Text tag="p" variant="textSM" class="text-base-500">
          &copy; {new Date().getFullYear()} Spot On Mobile Detailing. All rights reserved.
        </Text>
        <div class="flex gap-6">
          {
            ["Facebook"].map((social) => (
              <a
                href="https://www.facebook.com/DadSaysJokes/"
                class="text-xs text-base-500 hover:text-accent-500 transition-colors"
              >
                {social}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</footer>
